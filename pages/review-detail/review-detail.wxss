/* 评价详情页面样式 */
.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.product-section {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 30rpx;
  background: #fff;
  margin-bottom: 20rpx;
}

.product-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.product-title {
  font-size: 28rpx;
  color: #333;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.product-price {
  font-size: 32rpx;
  color: #ff6b00;
  font-weight: 600;
}

.review-section {
  background: #fff;
  padding: 30rpx;
}

.review-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #f0f0f0;
}

.user-detail {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.nickname {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.time {
  font-size: 24rpx;
  color: #999;
}

.rating {
  display: flex;
  gap: 4rpx;
}

.star {
  font-size: 28rpx;
  color: #ff9500;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.tag {
  padding: 8rpx 16rpx;
  background: #fff0e6;
  color: #ff6b00;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.content {
  margin-bottom: 24rpx;
}

.content text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.review-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 200rpx;
  color: #999;
  font-size: 28rpx;
}
