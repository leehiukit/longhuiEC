<!-- 地址管理 -->
<view class="page">
  <!-- 地址列表 -->
  <view class="address-list">
    <view 
      class="address-card" 
      wx:for="{{addresses}}" 
      wx:key="id"
      bindtap="selectAddress"
      data-item="{{item}}"
    >
      <view class="card-main">
        <view class="name-row">
          <text class="name">{{item.name}}</text>
          <text class="phone">{{item.phone}}</text>
          <text class="default-tag" wx:if="{{item.isDefault}}">默认</text>
        </view>
        <text class="detail">{{item.province}}{{item.city}}{{item.district}}{{item.detail}}</text>
      </view>
      
      <view class="card-actions" catchtap="stopPropagation">
        <view class="action-btn" data-id="{{item.id}}" bindtap="editAddress">
          <text>✏️</text><text>编辑</text>
        </view>
        <view class="action-btn delete" data-id="{{item.id}}" bindtap="deleteAddress">
          <text>🗑️</text><text>删除</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-address" wx:if="{{addresses.length === 0}}">
      <text class="empty-icon">📍</text>
      <text class="empty-text">暂无收货地址</text>
      <text class="empty-tip">点击下方按钮添加地址</text>
    </view>
  </view>

  <!-- 添加按钮 -->
  <button class="add-btn safe-area-bottom" bindtap="addAddress">+ 新增地址</button>
</view>

<!-- 编辑弹窗 -->
<view class="modal-mask" wx:if="{{showModal}}" bindtap="closeModal">
  <view class="modal-content" catchtap="stopPropagation">
    <view class="modal-header">
      <text>{{editId ? '编辑' : '新增'}}地址</text>
    </view>
    
    <view class="form-group">
      <input 
        class="form-input" 
        placeholder="收货人姓名" 
        value="{{formData.name}}"
        bindinput="onInput"
        data-field="name"
      />
    </view>
    
    <view class="form-group">
      <input 
        class="form-input" 
        placeholder="手机号码" 
        type="number"
        value="{{formData.phone}}"
        bindinput="onInput"
        data-field="phone"
      />
    </view>
    
    <view class="form-group">
      <picker mode="region" value="{{region}}" bindchange="onRegionChange">
        <view class="form-input picker-value">{{region[0] || '请选择省市区'}} {{region[1]}} {{region[2]}}</view>
      </picker>
    </view>
    
    <view class="form-group textarea-group">
      <textarea 
        class="form-textarea" 
        placeholder="详细地址（街道、门牌号等）"
        value="{{formData.detail}}"
        bindinput="onInput"
        data-field="detail"
      />
    </view>
    
    <label class="default-check">
      <checkbox checked="{{formData.isDefault}}" bindchange="onDefaultChange" />
      <text>设为默认地址</text>
    </label>
    
    <view class="modal-footer">
      <button class="btn-cancel" bindtap="closeModal">取消</button>
      <button class="btn-save" bindtap="saveAddress">保存</button>
    </view>
  </view>
</view>