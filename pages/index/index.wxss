/* ========== 首页样式 - 有闲甄选 ========== */
.page {
  min-height: 100vh;
  background: #faf8f5;
}

/* 搜索栏 */
.search-bar {
  padding: 20rpx 24rpx;
  background: #fff;
}
.search-input {
  height: 68rpx;
  background: #f6f3ed;
  border-radius: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #bbb;
  font-size: 26rpx;
}
.search-icon { margin-right: 10rpx; font-size: 26rpx; }

/* ====== 品牌横幅 ====== */
.brand-banner {
  background: linear-gradient(135deg, #fff9f0, #fff4e0);
  padding: 36rpx 30rpx 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 2rpx;
}
.brand-logo {
  width: 100rpx;
  height: 100rpx;
  border-radius: 20rpx;
}
.brand-text-logo {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.brand-name {
  font-size: 38rpx;
  font-weight: bold;
  color: var(--primary-color, #E8952A);
  letter-spacing: 4rpx;
}
.brand-en {
  font-size: 18rpx;
  color: #c0a068;
  letter-spacing: 2rpx;
  margin-top: 4rpx;
}
.brand-slogan {
  color: #b89858;
  font-size: 23rpx;
  margin-top: 12rpx;
}
/* 运营数据 */
.brand-stats {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.65);
  border-radius: 20rpx;
  padding: 20rpx 36rpx;
  gap: 32rpx;
}
.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 96rpx;
}
.stat-num {
  font-size: 30rpx;
  font-weight: 700;
  color: #E8952A;
}
.stat-label {
  font-size: 20rpx;
  color: #bbb;
  margin-top: 4rpx;
}
.stat-divider {
  width: 1rpx;
  height: 44rpx;
  background: #e8d5a8;
}

/* 轮播图 */
.banner { width: 100%; height: 320rpx; }
.banner-img { width: 100%; height: 100%; }
/* 文字卡片 Banner */
.banner-card {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 48rpx;
}
.banner-card-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 4rpx;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
}
.banner-card-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.92);
  letter-spacing: 2rpx;
}

/* 分类入口 */
.category-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 32rpx 20rpx;
  background: #fff;
  margin-bottom: 16rpx;
}
.category-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}
.category-icon {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(145deg, #E8952A, #F5C066);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 38rpx;
  box-shadow: 0 4rpx 16rpx rgba(232, 149, 42, 0.25);
  margin-bottom: 14rpx;
}
.category-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  background: #fff;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 14rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}
.category-icon-img {
  width: 72rpx;
  height: 72rpx;
}
.category-name { font-size: 24rpx; color: #555; }

/* 区域标题 */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  background: #fff;
}
.title-left { display: flex; align-items: baseline; gap: 16rpx; }
.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  position: relative;
  padding-left: 22rpx;
}
.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 6rpx;
  bottom: 6rpx;
  width: 6rpx;
  height: calc(100% - 12rpx);
  background: linear-gradient(180deg, #E8952A, #F5C066);
  border-radius: 3rpx;
}
.section-sub { font-size: 22rpx; color: #c0a068; }
.section-more { font-size: 26rpx; color: #999; }

/* 商品列表 */
.product-list { padding: 0 14rpx; }
.product-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 18rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(200, 170, 110, 0.08);
  transition: transform 0.15s ease;
}
.product-img-wrap {
  position: relative;
  width: 248rpx;
  height: 248rpx;
  flex-shrink: 0;
}
.product-img { width: 100%; height: 100%; }
.product-tag {
  position: absolute;
  left: 0;
  top: 0;
  background: linear-gradient(135deg, #E8952A, #F5C066);
  color: #fff;
  font-size: 20rpx;
  padding: 5rpx 16rpx;
  border-radius: 0 0 14rpx 0;
  font-weight: 500;
}
.product-badge {
  position: absolute;
  right: 0;
  top: 0;
  background: rgba(232, 80, 70, 0.92);
  color: #fff;
  font-size: 19rpx;
  padding: 4rpx 13rpx;
  border-radius: 0 0 0 14rpx;
  font-weight: 500;
}
.product-info {
  flex: 1;
  padding: 22rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
  overflow: hidden;
}
.product-title {
  font-size: 28rpx;
  color: #333;
  line-height: 1.45;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.product-specs { font-size: 24rpx; color: #999; margin-top: 10rpx; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.product-meta {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 6rpx;
}
.product-stock { font-size: 22rpx; color: #E8952A; }
.product-sales { font-size: 22rpx; color: #ccc; }
.product-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}
.product-price {
  flex: 1;
  min-width: 0;
}
.save-info {
  flex-shrink: 0;
}
.save-info text {
  font-size: 21rpx;
  color: #E8952A;
  background: #fef6ec;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  white-space: nowrap;
}
/* 底部提示 */
.load-more {
  text-align: center;
  padding: 48rpx 0;
  color: #d0c0a0;
  font-size: 24rpx;
}
.load-line {
  width: 120rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #e8d5a8, transparent);
  margin: 0 auto 16rpx;
}