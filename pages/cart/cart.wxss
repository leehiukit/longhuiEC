/* ========== 购物车 - 有闲甄选 ========== */
.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 180rpx;
}
.empty-icon { font-size: 120rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 30rpx; color: #bbb; margin-bottom: 40rpx; }
.btn-go {
  background: linear-gradient(135deg, #E8952A, #F5C066);
  color: #fff;
  font-size: 28rpx;
  width: 280rpx;
  height: 76rpx;
  border-radius: 38rpx;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(232,149,42,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  line-height: 1;
}
.btn-go::after { display: none; }

.select-all {
  display: flex; align-items: center; justify-content: space-between;
  padding: 26rpx 28rpx; background: #fff; border-bottom: 1rpx solid #f0ece4;
}
.checkbox-wrap { display: flex; align-items: center; gap: 12rpx; font-size: 28rpx; color: #555; }
.delete-btn { font-size: 26rpx; color: #E85A4F; }

.cart-item {
  display: flex; align-items: center;
  background: #fff; padding: 26rpx 22rpx;
  margin-bottom: 3rpx; gap: 18rpx;
}
.item-img {
  width: 186rpx; height: 186rpx;
  border-radius: 14rpx; flex-shrink: 0;
}
.item-info {
  flex: 1; display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 186rpx;
}
.item-title { font-size: 27rpx; color: #333; line-height: 1.45; }
.item-bottom { display: flex; align-items: center; justify-content: space-between; }

/* 数量控制 */
.quantity-control {
  display: flex; align-items: center;
  border: 1rpx solid #e8d8c4; border-radius: 10rpx;
}
.qty-btn, .qty-num {
  width: 58rpx; height: 50rpx; line-height: 50rpx;
  text-align: center; font-size: 26rpx; color: #666;
}
.qty-btn { color: #888; background: #faf8f5; }

/* 底部结算 */
.checkout-bar {
  position: fixed; left: 0; right: 0; bottom: 0;
  display: flex; align-items: center; justify-content: space-between;
  background: #fff; padding: 16rpx 24rpx;
  box-shadow: 0 -4rpx 20rpx rgba(200,170,110,0.1); z-index: 100; gap: 16rpx;
}
.price-info { flex: 1; text-align: right; }
.total-label { font-size: 28rpx; color: #555; }
.total-price {
  font-size: 38rpx; color: #E8952A; font-weight: bold;
  margin-left: 8rpx;
}
.btn-checkout {
  background: linear-gradient(135deg, #E8952A, #F5C066);
  color: #fff;
  font-size: 29rpx;
  height: 80rpx;
  width: 220rpx;
  border-radius: 40rpx;
  border: none;
  margin: 0;
  box-shadow: 0 6rpx 20rpx rgba(232,149,42,0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  line-height: 1;
}
.btn-checkout::after { display: none; }
.btn-checkout.disabled { opacity: 0.45; box-shadow: none; }