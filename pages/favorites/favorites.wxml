<!-- 我的收藏 -->
<view class="page">
  <!-- 收藏列表 -->
  <view class="fav-list" wx:if="{{favorites.length > 0}}">
    <view
      class="fav-card"
      wx:for="{{favorites}}"
      wx:key="id"
      bindtap="goDetail"
      data-id="{{item.id}}"
    >
      <image class="fav-img" src="{{item.image}}" mode="aspectFill" />
      <view class="fav-info">
        <text class="fav-title ellipsis-2">{{item.title}}</text>
        <view class="fav-bottom">
          <text class="fav-price">¥{{item.price}}</text>
          <view class="fav-delete" catchtap="removeFav" data-id="{{item.id}}">
            <text>❤️ 已收藏</text>
          </view>
        </view>
      </view>
    </view>
    <view class="fav-clear-all" bindtap="clearAll">
      <text>清空收藏</text>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:else>
    <text class="empty-icon">💝</text>
    <text class="empty-title">还没有收藏</text>
    <text class="empty-tip">遇到心仪的商品，点击收藏吧～</text>
    <button class="btn-go-shop" bindtap="goHome">去逛逛</button>
  </view>
</view>
