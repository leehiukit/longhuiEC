/* ========== 订单确认 - 有闲甄选 ========== */

/* 地址区 */
.address-section {
  display: flex; align-items: center;
  background: #fff; padding: 32rpx 28rpx;
  margin-bottom: 12rpx;
}
.address-info { flex: 1; }
.address-top { display: flex; align-items: center; gap: 18rpx; margin-bottom: 14rpx; }
.name { font-size: 32rpx; font-weight: bold; color: #333; }
.phone { font-size: 28rpx; color: #777; }
.address-detail { font-size: 26rpx; color: #999; line-height: 1.55; }
.no-address {
  flex: 1; display: flex; align-items: center; justify-content: center;
  gap: 10rpx; color: #ccc; font-size: 28rpx; padding: 20rpx 0;
}
.arrow { color: #ddd; font-size: 34rpx; }

/* 商品区 */
.goods-section, .coupon-section, .remark-section {
  background: #fff; padding: 28rpx; margin-bottom: 12rpx;
}
.section-title { font-size: 30rpx; font-weight: bold; color: #333; margin-bottom: 22rpx; }
.goods-item {
  display: flex; align-items: center;
  padding: 18rpx 0; border-top: 1rpx solid #f8f4ee;
}
.goods-img {
  width: 166rpx; height: 166rpx; border-radius: 13rpx; margin-right: 20rpx;
}
.goods-info {
  flex: 1; display: flex; flex-direction: column; justify-content: space-between;
}
.goods-title { font-size: 27rpx; color: #333; line-height: 1.45; }
.goods-bottom { display: flex; justify-content: space-between; align-items: center; }
.quantity { color: #aaa; font-size: 25rpx; }

/* 优惠券 & 备注 */
.coupon-section {
  display: flex; align-items: center; justify-content: space-between;
  font-size: 28rpx; color: #333;
}
.coupon-right { display: flex; align-items: center; gap: 8rpx; }
.coupon-value { color: #E8952A; font-weight: bold; }
.coupon-clear {
  width: 36rpx; height: 36rpx; line-height: 34rpx;
  background: #ddd; color: #fff; border-radius: 50%;
  text-align: center; font-size: 24rpx;
  margin-left: 8rpx; flex-shrink: 0;
}
.no-coupon { color: #bbb; }
.remark-section {
  display: flex; align-items: center; justify-content: space-between;
  font-size: 28rpx; color: #333;
}
.remark-input { flex: 1; text-align: right; color: #777; }

/* 价格明细 */
.price-section { background: #fff; padding: 28rpx; margin-bottom: 12rpx; }
.price-row {
  display: flex; justify-content: space-between; padding: 14rpx 0;
  font-size: 26rpx; color: #888;
}
.price-row.discount { color: #52c41a; }

/* 提交栏 */
.submit-bar {
  position: fixed; left: 0; right: 0; bottom: 0;
  display: flex; align-items: center;
  background: #fff; padding: 16rpx 28rpx;
  box-shadow: 0 -4rpx 20rpx rgba(200,170,110,0.1); z-index: 100;
}
.submit-bar .price-info {
  flex-shrink: 0;
  display: flex; align-items: baseline; gap: 6rpx;
}
.final-price {
  font-size: 42rpx; color: #E8952A; font-weight: bold;
}
.btn-submit {
  position: absolute; right: 28rpx;
  background: linear-gradient(135deg, #E8952A, #F5C066); color: #fff;
  font-size: 31rpx; font-weight: 500;
  height: 84rpx; line-height: 84rpx;
  width: 270rpx; border-radius: 42rpx; border: none; margin: 0;
  letter-spacing: 4rpx;
  box-shadow: 0 6rpx 22rpx rgba(232,149,42,0.38);
  display: flex; align-items: center; justify-content: center;
  padding: 0;
}
.btn-submit::after { border: none; }

/* ========== 支付弹层 ========== */
.payment-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0);
  z-index: 200;
  opacity: 0;
  pointer-events: none;
  transition: background 0.25s, opacity 0.25s;
}
.payment-mask.show {
  background: rgba(0,0,0,0.45);
  opacity: 1;
  pointer-events: auto;
}

.payment-sheet {
  position: fixed; left: 0; right: 0; bottom: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.33, 1, 0.68, 1);
  z-index: 201;
  padding-bottom: env(safe-area-inset-bottom);
}
.payment-sheet.show {
  transform: translateY(0);
}

.pay-header {
  display: flex; align-items: center; justify-content: center;
  flex-direction: column;
  padding: 36rpx 28rpx 24rpx;
  position: relative;
  border-bottom: 1rpx solid #f5f0e8;
}
.pay-title { font-size: 30rpx; color: #999; margin-bottom: 12rpx; }
.pay-amount {
  font-size: 56rpx; font-weight: bold; color: #E8952A;
  letter-spacing: 2rpx;
}
.pay-close {
  position: absolute; right: 28rpx; top: 36rpx;
  width: 56rpx; height: 56rpx;
  display: flex; align-items: center; justify-content: center;
  border-radius: 50%; background: #f5f5f5;
  font-size: 32rpx; color: #999;
}

.pay-methods { padding: 24rpx 28rpx; }
.pay-label { font-size: 26rpx; color: #999; margin-bottom: 16rpx; }

.pay-method {
  display: flex; align-items: center;
  padding: 28rpx 16rpx;
  border: 2rpx solid #f0ece4;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  transition: border-color 0.2s;
}
.pay-method.active { border-color: #E8952A; }

.pay-method-icon {
  width: 64rpx; height: 64rpx;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 36rpx;
  margin-right: 18rpx;
  flex-shrink: 0;
}
.wechat-icon { background: #e8f9e8; }


.pay-method-name { flex: 1; font-size: 28rpx; color: #333; }

.pay-radio {
  width: 36rpx; height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #ddd;
  transition: all 0.2s;
}
.pay-radio.checked {
  border-color: #E8952A;
  background: #E8952A;
  box-shadow: inset 0 0 0 3rpx #fff;
  border-width: 5rpx;
}

.pay-footer { padding: 16rpx 28rpx 32rpx; }
.pay-tip {
  text-align: center; font-size: 22rpx; color: #ccc;
  margin-bottom: 16rpx;
  display: flex; align-items: center; justify-content: center;
  gap: 8rpx;
}
.pay-tip.paying { color: #E8952A; }
.paying-dot {
  width: 12rpx; height: 12rpx;
  background: #E8952A; border-radius: 50%;
  animation: pulse 1s infinite;
}
@keyframes pulse {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 1; }
}

.btn-pay-confirm {
  width: 100%; height: 92rpx; line-height: 92rpx;
  background: linear-gradient(135deg, #E8952A, #F5C066);
  color: #fff; font-size: 32rpx; font-weight: 500;
  border-radius: 46rpx; border: none;
  box-shadow: 0 8rpx 28rpx rgba(232,149,42,0.35);
}
.btn-pay-confirm::after { border: none; }
.btn-pay-confirm[disabled] { opacity: 0.5; }