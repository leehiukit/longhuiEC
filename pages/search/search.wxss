/* 搜索页样式 */
.search-header {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #fff;
  gap: 16rpx;
}
.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 32rpx;
  padding: 16rpx 24rpx;
}
.search-icon { margin-right: 12rpx; }
.search-input {
  flex: 1;
  font-size: 28rpx;
  height: 40rpx;
}
.cancel-btn { color: #666; font-size: 28rpx; }

/* 历史和热门 */
.history-section, .hot-section {
  background: #fff;
  padding: 30rpx 24rpx;
  margin-top: 16rpx;
}
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}
.clear-btn {
  font-size: 26rpx;
  color: #999;
  font-weight: normal;
}

/* 历史标签 */
.history-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.history-tag {
  background: #f5f5f5;
  color: #666;
  padding: 14rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
}

/* 热门列表 */
.hot-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.hot-item {
  width: calc(33.33% - 12rpx);
  text-align: center;
  background: #f9f9f9;
  padding: 20rpx 10rpx;
  border-radius: 10rpx;
  font-size: 26rpx;
  color: #333;
}

/* 结果 */
.result-section {
  background: #f5f5f5;
  padding: 16rpx;
  min-height: 100vh;
}
.result-header {
  display: flex;
  justify-content: space-between;
  padding: 16rpx;
  font-size: 26rpx;
  color: #888;
}
.sort-text { color: #E8952A; }

.product-list .product-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
}
.product-img {
  width: 220rpx;
  height: 220rpx;
}
.product-info {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.product-title {
  font-size: 27rpx;
  color: #333;
  line-height: 1.4;
}
.product-sales { font-size: 22rpx; color: #aaa; }

.empty-result {
  text-align: center;
  padding: 100rpx;
  color: #999;
}