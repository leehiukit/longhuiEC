<!-- 订单列表 - 有闲甄选 -->
<view class="page">
  <!-- 标签切换 -->
  <view class="tab-bar">
    <view 
      wx:for="{{tabs}}" wx:key="key"
      class="tab {{activeTab === item.key ? 'active' : ''}}"
      data-tab="{{item.key}}"
      bindtap="switchTab"
    >{{item.label}}</view>
  </view>

  <!-- 订单列表 -->
  <view wx:if="{{!isEmpty}}" class="order-list">
    <view class="order-card" wx:for="{{orders}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
      
      <!-- 订单头部 -->
      <view class="order-header">
        <view class="order-id">
          <text>订单号：{{item.id}}</text>
        </view>
        <text class="order-status" style="color: {{item.statusInfo.color}};">
          {{item.statusInfo.icon}} {{item.statusInfo.label}}
        </text>
      </view>

      <!-- 商品列表 -->
      <view 
        class="order-product" 
        wx:for="{{item.items}}" 
        wx:for-item="product" 
        wx:key="id"
      >
        <image class="product-img" src="{{product.image}}" mode="aspectFill" />
        <view class="product-info">
          <text class="product-title ellipsis-2">{{product.title}}</text>
          <view class="product-price">
            <text>¥{{product.price}}</text>
            <text class="product-qty">x{{product.quantity}}</text>
          </view>
        </view>
      </view>

      <!-- 金额 -->
      <view class="order-total">
        <text>共 {{item.items.length}} 件</text>
        <text>实付：</text>
        <text class="total-amount">¥{{item.finalPrice.toFixed(2)}}</text>
      </view>

      <!-- 物流信息（已发货时显示） -->
      <view class="logistics-info" wx:if="{{item.carrier || item.trackingNumber}}">
        <text class="logistics-icon">🚚</text>
        <text class="logistics-text" wx:if="{{item.carrier}}">承运：{{item.carrier}}</text>
        <text class="logistics-text" wx:if="{{item.trackingNumber}}">单号：{{item.trackingNumber}}</text>
        <text class="logistics-text" wx:if="{{item.shippedAt}}">发货：{{item.shippedAt}}</text>
      </view>

      <!-- 待付款倒计时 -->
      <view class="order-remaining" wx:if="{{item.status === 'pending' && !item.expired}}">
        ⏱ {{item.remainingText}}
      </view>
      <view class="order-remaining expired" wx:if="{{item.status === 'pending' && item.expired}}">
        ⚠️ 订单已过期，请重新下单
      </view>

      <!-- 操作按钮 -->
      <view class="order-actions">
        <!-- 售后状态提示 -->
        <text class="refund-status-tag" wx:if="{{item.hasRefund}}">{{item.refundStatusText}}</text>

        <!-- 取消订单（仅待付款） -->
        <view 
          wx:if="{{item.status === 'pending'}}"
          class="btn-cancel"
          data-id="{{item.id}}"
          catchtap="cancelOrder"
        >取消订单</view>

        <!-- 仅退款（待发货） -->
        <view
          wx:if="{{item.showRefundOnly}}"
          class="btn-cancel"
          data-id="{{item.id}}"
          data-type="refund"
          catchtap="applyAfterSale"
        >仅退款</view>

        <!-- 退货退款（待收货/已完成） -->
        <view
          wx:if="{{item.showReturnRefund}}"
          class="btn-cancel"
          data-id="{{item.id}}"
          data-type="return"
          catchtap="applyAfterSale"
        >退货退款</view>

        <!-- 查看售后详情 -->
        <view 
          wx:if="{{item.showRefundDetail}}"
          class="btn-cancel"
          data-refund-id="{{item.refundId}}"
          catchtap="viewRefund"
        >售后详情</view>

        <!-- 主操作按钮 -->
        <view 
          wx:if="{{item.statusInfo.action}}"
          class="btn-primary"
          data-id="{{item.id}}"
          data-status="{{item.status}}"
          catchtap="handleOrderAction"
        >{{item.statusInfo.action}}</view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:else class="empty-state">
    <text class="empty-icon">📋</text>
    <text class="empty-text">暂无相关订单</text>
    <text class="empty-sub">去选购心仪的二手好物吧</text>
    <navigator url="/pages/index/index" open-type="switchTab">
      <button class="go-shop-btn">去逛逛</button>
    </navigator>
  </view>
</view>