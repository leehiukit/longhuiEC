<!-- 分类页 -->
<view class="page">
  <view class="category-container">
    <!-- 左侧分类 -->
    <scroll-view scroll-y class="category-left">
      <view 
        wx:for="{{categories}}" 
        wx:key="id"
        class="category-item {{currentCategory === item.id ? 'active' : ''}}"
        data-id="{{item.id}}"
        bindtap="selectCategory"
      >
        <image wx:if="{{item.iconImage}}" class="cat-icon-img" src="{{item.iconImage}}" mode="aspectFit" />
        <view wx:else class="cat-icon-txt">{{item.icon}}</view>
        <text>{{item.name}}</text>
      </view>
    </scroll-view>
    
    <!-- 右侧商品 -->
    <scroll-view scroll-y class="product-right">
      <view class="filter-bar">
        <view 
          wx:for="{{sortOptions}}" 
          wx:key="value"
          class="filter-item {{sortBy === item.value ? 'active' : ''}}"
          data-value="{{item.value}}"
          bindtap="changeSort"
        >{{item.label}}</view>
      </view>
      
      <!-- 商品列表 -->
      <view class="product-grid">
        <view 
          class="product-card" 
          wx:for="{{products}}" 
          wx:key="id"
          bindtap="goDetail"
          data-id="{{item.id}}"
        >
          <image class="product-img" src="{{item.image}}" mode="aspectFill" />
          <view class="product-info">
            <text class="product-title ellipsis-2">{{item.title}}</text>
            <view class="product-price-row">
              <text class="price">¥{{item.price}}</text>
              <text class="product-stock" wx:if="{{item.stock > 0}}">库存{{item.stock}}件</text>
              <text class="product-sales">已售{{item.sales}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty" wx:if="{{products.length === 0 && !loading}}">
        <text>暂无商品</text>
      </view>
    </scroll-view>
  </view>
</view>