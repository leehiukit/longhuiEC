/* ========== 用户中心 - 有闲甄选 ========== */

/* 头部 */
.header {
  position: relative;
  padding-bottom: 20rpx;
}
.header-bg {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 360rpx;
  background: linear-gradient(160deg, #E8952A 0%, #F5C066 55%, #FFE4B5 100%);
  border-radius: 0 0 50rpx 50rpx;
}
.header-content {
  position: relative;
  z-index: 1;
  padding: 56rpx 32rpx 16rpx;
}

/* 用户信息 */
.user-info, .login-tip {
  display: flex;
  align-items: center;
  gap: 22rpx;
}
.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.8);
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.12);
  flex-shrink: 0;
}
.avatar-guest { opacity: 0.6; }
.info-text {
  display: flex;
  flex-direction: column;
  color: #fff;
}
.nickname {
  font-size: 34rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
}
.user-level {
  font-size: 23rpx;
  opacity: 0.85;
  margin-top: 8rpx;
  background: rgba(255,255,255,0.22);
  display: inline-block;
  padding: 3rpx 14rpx;
  border-radius: 16rpx;
  align-self: flex-start;
}
.edit-icon {
  margin-left: auto;
  font-size: 36rpx;
  color: rgba(255,255,255,0.7);
}
/* 品牌标语 */
.slogan-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: 28rpx;
}
.slogan-brand {
  font-size: 26rpx;
  font-weight: bold;
  color: rgba(255,255,255,0.95);
  letter-spacing: 4rpx;
}
.slogan-dot {
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
}
.slogan-text {
  font-size: 23rpx;
  color: rgba(255,255,255,0.7);
  letter-spacing: 3rpx;
}

/* 统计卡片 */
.stats-card {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: #fff;
  margin: -20rpx 28rpx 18rpx;
  border-radius: 20rpx;
  padding: 28rpx 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(200,170,110,0.1);
}
.stat-item { text-align: center; flex: 1; }
.stat-num {
  display: block;
  font-size: 38rpx;
  font-weight: bold;
  color: #333;
}
.stat-num.text-warning { color: #E8952A; }
.stat-label {
  font-size: 23rpx;
  color: #999;
  margin-top: 8rpx;
}
.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: #f0ece4;
}

/* 区块通用 */
.section {
  background: #fff;
  margin: 0 28rpx 18rpx;
  border-radius: 20rpx;
  padding: 26rpx 28rpx;
  overflow: hidden;
}
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 22rpx;
}
.arrow {
  font-size: 25rpx;
  color: #bbb;
  font-weight: normal;
}

/* 订单标签 */
.order-tabs { display: flex; }
.tab-item {
  flex: 1;
  text-align: center;
  position: relative;
  font-size: 24rpx;
  color: #666;
  padding: 16rpx 0;
}
.tab-icon {
  display: block;
  font-size: 44rpx;
  margin-bottom: 8rpx;
}
.tab-badge {
  position: absolute;
  top: 8rpx;
  right: 18rpx;
  background: linear-gradient(135deg, #E85A4F, #FF7B68);
  color: #fff;
  font-size: 19rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  text-align: center;
  border-radius: 16rpx;
  padding: 0 7rpx;
}

/* 菜单 */
.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #faf8f5;
}
.menu-item:last-child { border: none; }
.menu-left {
  display: flex;
  align-items: center;
  gap: 18rpx;
  font-size: 29rpx;
  color: #333;
}
.menu-icon { font-size: 38rpx; }
.menu-desc {
  font-size: 22rpx;
  color: #ccc;
  margin-left: auto;
  margin-right: 8rpx;
}

/* 客服 */
.contact-section { padding: 20rpx 28rpx; }
.contact-btn {
  width: 100%;
  background: transparent;
  color: #E8952A;
  border: 2rpx solid #E8952A;
  font-size: 28rpx;
  height: auto;
  line-height: 1.6;
  padding: 18rpx 12rpx;
  border-radius: 42rpx;
  letter-spacing: 4rpx;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}
.contact-btn::after {
  display: none;
}

/* 退出登录 */
.logout-section { padding: 8rpx 28rpx 20rpx; }
.logout-btn {
  text-align: center;
  padding: 24rpx 0;
  color: #ccc;
  font-size: 26rpx;
}

/* 底部版权 */
.footer {
  text-align: center;
  padding: 40rpx 0 80rpx;
}
.footer-brand {
  display: block;
  font-size: 24rpx;
  color: #c0a068;
  letter-spacing: 4rpx;
  margin-bottom: 10rpx;
}
.footer-copy {
  display: block;
  font-size: 20rpx;
  color: #ddd;
}