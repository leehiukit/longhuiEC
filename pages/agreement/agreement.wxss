/* ========== 协议详情页样式 ========== */
.page {
  min-height: 100vh;
  background: #faf8f5;
  padding-bottom: 100rpx;
}

.agreement-content {
  padding: 40rpx 36rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  text-align: center;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.update-time {
  text-align: center;
  font-size: 22rpx;
  color: #bbb;
  margin-bottom: 48rpx;
}

.section {
  margin-bottom: 36rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 18rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #E8952A;
  line-height: 1.3;
}

.para {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.85;
  margin-bottom: 12rpx;
  text-align: justify;
  letter-spacing: 0.5rpx;
}

.bold {
  font-weight: 600;
  color: #333;
  font-size: 27rpx;
}
