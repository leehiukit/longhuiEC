/* 设置页样式 */
.page {
  min-height: 100vh;
  background: #faf8f5;
  padding-bottom: 80rpx;
}

.section {
  background: #fff;
  margin: 18rpx 28rpx;
  border-radius: 20rpx;
  padding: 10rpx 0;
  overflow: hidden;
}

.section-title {
  font-size: 24rpx;
  color: #bbb;
  padding: 16rpx 28rpx 8rpx;
}

.row {
  display: flex;
  align-items: center;
  padding: 26rpx 28rpx;
  border-bottom: 1rpx solid #faf8f5;
}

.row:last-child {
  border-bottom: none;
}

.row-label {
  font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
}

.row-value {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
  color: #aaa;
  margin-right: 12rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.row-value.highlight {
  color: #E8952A;
}

.arrow {
  font-size: 30rpx;
  color: #ddd;
  flex-shrink: 0;
}

.row-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-left: auto;
  margin-right: 12rpx;
}

/* 退出登录 */
.logout-section {
  padding: 40rpx 60rpx 20rpx;
}

.btn-logout {
  width: 100%;
  height: 84rpx;
  font-size: 30rpx;
  color: #E85A4F;
  background: #fff;
  border: 2rpx solid #f0ece4;
  border-radius: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  line-height: 1;
}

.btn-logout::after {
  display: none;
}

.footer {
  text-align: center;
  padding: 40rpx 0 60rpx;
  font-size: 22rpx;
  color: #ddd;
}
