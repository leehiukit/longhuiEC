<!-- 设置 -->
<view class="page">
  <!-- 个人信息区 -->
  <view class="section">
    <view class="section-title">个人信息</view>

    <view class="row" bindtap="editAvatar">
      <text class="row-label">头像</text>
      <image class="row-avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
      <text class="arrow">›</text>
    </view>

    <view class="row" bindtap="editNickname">
      <text class="row-label">昵称</text>
      <text class="row-value">{{userInfo.nickName || '点击设置'}}</text>
      <text class="arrow">›</text>
    </view>

    <view class="row" bindtap="showPhone">
      <text class="row-label">手机号</text>
      <text class="row-value">{{userInfo.phone || '未绑定'}}</text>
      <text class="arrow">›</text>
    </view>

    <view class="row">
      <text class="row-label">会员等级</text>
      <text class="row-value highlight">Lv.{{userInfo.level || 1}} · 甄选达人</text>
    </view>
  </view>

  <!-- 通用设置 -->
  <view class="section">
    <view class="section-title">通用</view>

    <view class="row" bindtap="clearCache">
      <text class="row-label">清除缓存</text>
      <text class="row-value">{{cacheSize}}</text>
      <text class="arrow">›</text>
    </view>

    <view class="row" bindtap="checkUpdate">
      <text class="row-label">检查更新</text>
      <text class="row-value">v{{appVersion}}</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 关于 -->
  <view class="section">
    <view class="section-title">关于</view>

    <view class="row" bindtap="showAbout">
      <text class="row-label">关于有闲甄选</text>
      <text class="arrow">›</text>
    </view>

    <view class="row" bindtap="toAgreement">
      <text class="row-label">服务协议</text>
      <text class="arrow">›</text>
    </view>

    <view class="row" bindtap="toPrivacy">
      <text class="row-label">隐私政策</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section">
    <button class="btn-logout" bindtap="handleLogout">退出登录</button>
  </view>

  <view class="footer">
    <text>有闲甄选 v{{appVersion}}</text>
  </view>
</view>
